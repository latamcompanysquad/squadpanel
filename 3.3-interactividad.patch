+// ── FILTROS ───────────────────────────────────────────────────────────────────
+const filters = { t1: true, t2: true, veh: true, dead: false };
+
+function toggleFilter(key) {
+  filters[key] = !filters[key];
+  document.getElementById('f' + key).classList.toggle('active', filters[key]);
+  applyFilters();
+}
+
+function playerPassesFilter(p) {
+  if (!filters.t1 && p.teamID === 1) return false;
+  if (!filters.t2 && p.teamID === 2) return false;
+  if (!filters.veh && p.vehicle)     return false;
+  if (!filters.dead && !p.isAlive)   return false;
+  return true;
+}
+
+function applyFilters() {
+  for (const id of Object.keys(markers)) {
+    const m = markers[id];
+    const p = m._playerData;
+    if (!p) continue;
+    const visible = playerPassesFilter(p) && p.position;
+    if (visible && !map.hasLayer(m)) map.addLayer(m);
+    if (!visible && map.hasLayer(m)) map.removeLayer(m);
+  }
+}
+
+// ── FOLLOW MODE ───────────────────────────────────────────────────────────────
