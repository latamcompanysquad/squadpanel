+// ── ROL (categoría) ─────────────────────────────────────────────────────────────
+function roleCategory(p) {
+  if (p.isLeader) return 'leader';
+  const r = (p.role || '').toLowerCase();
+  if (r.includes('medic')) return 'medic';
+  if (r.includes('engineer') || r.includes('sapper')) return 'engineer';
+  if (r.includes('officer')) return 'officer';
+  return 'infantry';
+}
