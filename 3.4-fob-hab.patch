+// ── FOB/HAB MARKERS (rescatado de maqueta antigua) ──────────────────────────────
+let fobMarkersLayer = null;
+
+function initFobLayer() {
+  if (!fobMarkersLayer) {
+    fobMarkersLayer = L.featureGroup().addTo(map);
+  } else {
+    fobMarkersLayer.clearLayers();
+  }
+}
+
+function clearFobMarkers() {
+  if (fobMarkersLayer) {
+    fobMarkersLayer.clearLayers();
+  }
+}
+
+function renderFobMarker(fob, corners) {
+  if (!fobMarkersLayer) return;
+  
+  // Extraer datos (compatible con múltiples formatos)
+  const pos = fob.pos || fob.position || { x: 0, y: 0 };
+  const teamID = fob.teamID || fob.team || 1;
+  const habName = fob.habName || fob.name || `FOB${teamID}`;
+  const constructRadius = fob.construct_radius || 15000;
+  const exclusionRadius = fob.exclusion_radius || 30000;
+  
+  const latLng = gameToLatLng(pos, corners);
+  
+  // Círculo de EXCLUSIÓN (punteado rojo)
+  L.circle(latLng, {
+    radius: metersToMapUnits(exclusionRadius, corners),
+    color: "#e0584f",
+    weight: 1.5,
+    fillOpacity: 0.03,
+    dashArray: "4,5",
+  }).addTo(fobMarkersLayer);
+  
+  // Círculo de CONSTRUCCIÓN (sólido ámbar)
+  L.circle(latLng, {
+    radius: metersToMapUnits(constructRadius, corners),
+    color: "#d9a441",
+    weight: 1.5,
+    fillOpacity: 0.05,
+  }).addTo(fobMarkersLayer);
+  
+  // MARCADOR con ícono (⚑ = símbolo de FOB)
+  const iconColor = teamID === 1 ? '#4fa6e8' : '#e0584f';
+  const habIcon = L.divIcon({
+    html: `<div style="
+      width:26px;height:26px;
+      background:${iconColor};
+      border-radius:50%;
+      border:1px solid #000;
+      display:flex;align-items:center;justify-content:center;
+      font-weight:700;font-size:12px;
+      color:#fff;box-shadow:0 0 3px rgba(0,0,0,0.8);
+      font-family:'Oswald',sans-serif;
+    ">⚑</div>`,
+    iconSize: [26, 26],
+    iconAnchor: [13, 13],
+    className: "fob-icon",
+  });
+  
+  const marker = L.marker(latLng, { icon: habIcon }).addTo(fobMarkersLayer);
+  marker.bindTooltip(`<strong>${habName}</strong><br/>Team ${teamID}`, {
+    className: "squad-tip",
+    direction: "top",
+  });
+}
+
+function updateFobs(fobArray, corners) {
+  if (!fobArray || !Array.isArray(fobArray) || fobArray.length === 0) {
+    clearFobMarkers();
+    return;
+  }
+  
+  initFobLayer();
+  fobArray.forEach(fob => {
+    try {
+      renderFobMarker(fob, corners);
+    } catch (e) {
+      console.warn('Error rendering FOB:', fob, e);
+    }
+  });
+}
