+/**
+ * Convierte metros en coordenadas del juego a unidades de mapa Leaflet.
+ * Rescatado de maqueta antigua para visualización de FOB circles.
+ */
+function metersToMapUnits(meters, corners) {
+  if (!corners || !corners.minX || !corners.maxX) return 0;
+  const xRange = Math.abs(corners.maxX - corners.minX);
+  return Math.abs(meters / xRange) * MAP_UNITS;
+}
+
+/**
+ * Interpolación lineal simple (rescatado de maqueta).
+ */
+function lerp(a, b, t) {
+  return a + (b - a) * t;
+}
