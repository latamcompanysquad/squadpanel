+     * @returns {string} Ruta del icono
+     */
+    function getVehicleIcon(vehicleName, vehicleType = null) {
+      if (!vehicleName) return 'resources/public__img__markers__weapons__test.webp';
+      
+      // 1. Buscar por nombre específico
+      if (VEHICLES_WITH_NAMED_ICONS[vehicleName]) {
+        return `resources/${VEHICLES_WITH_NAMED_ICONS[vehicleName]}`;
+      }
+      
+      // 2. Usar tipo si se proporciona
+      if (vehicleType && VEHICLE_TYPE_ICONS[vehicleType]) {
+        return `resources/${VEHICLE_TYPE_ICONS[vehicleType]}`;
+      }
+      
+      // 3. Fallback: test.webp
+      return 'resources/public__img__markers__weapons__test.webp';
+    }
+  </script>
   
